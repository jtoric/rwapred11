# =============================================================
# Primjer environment varijabli (.env.example)
# =============================================================
# Ova datoteka IDE U GIT — služi kao dokumentacija.
# Kopiraj je u .env i prilagodi vrijednosti:
#
#   cp .env.example .env          (Linux/macOS)
#   Copy-Item .env.example .env   (PowerShell)
#
# .env datoteka se NE COMMITTA (vidi .gitignore).
# U produkciji se env varovi postavljaju na platformi (Railway/Render).
# =============================================================

# -- Postgres (koristi docker-compose.yml i API) --
POSTGRES_DB=pl_reg
POSTGRES_USER=pl_user
POSTGRES_PASSWORD=pl_pass
DB_PORT=5432

# -- API konfiguracija --
# DATABASE_URL format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<db>
# "asyncpg" je async driver — mora se poklapati s onim u requirements.txt.
DATABASE_URL=postgresql+asyncpg://pl_user:pl_pass@localhost:5432/pl_reg

# Okruženje: "dev" uključuje debug logging i Swagger docs.
ENV=dev

# JWT tajne — u produkciji MORA biti jak random string!
# Generiraj npr. sa: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=change-me-in-production
JWT_ISSUER=sit-unizd
